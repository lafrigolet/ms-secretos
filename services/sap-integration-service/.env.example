PORT=3010
HOST=0.0.0.0
NODE_ENV=development

# ── Modo de operación ─────────────────────────────────────────────
# 'stub'    → datos ficticios locales, sin necesitar SAP (desarrollo)
# 'odata'   → SAP Gateway via OData/REST (producción recomendada)
# 'rfc'     → SAP RFC/BAPI via conexión directa (producción alternativa)
SAP_MODE=stub

# ── Credenciales SAP (solo necesarias si SAP_MODE != stub) ────────
SAP_BASE_URL=https://sap.secretosdelagua.com/sap/opu/odata/sap
SAP_CLIENT=100
SAP_USER=sda_api_user
SAP_PASSWORD=changeme
SAP_LANGUAGE=ES

# ── Caché (segundos) ──────────────────────────────────────────────
# Tiempo que se cachean los datos de SAP en memoria
# 0 = sin caché
CACHE_TTL_CUSTOMERS=300
CACHE_TTL_PRODUCTS=600
CACHE_TTL_PRICES=300
CACHE_TTL_STOCK=60
