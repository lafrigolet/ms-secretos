# ══════════════════════════════════════════════════════════════════
# Secretos del Agua — Variables de entorno para desarrollo local
# Copiar a .env y ajustar si es necesario
# NUNCA commitear .env con valores reales
# ══════════════════════════════════════════════════════════════════

# ── Entorno ───────────────────────────────────────────────────────
NODE_ENV=development

# ── JWT (compartido entre servicios que validan tokens) ───────────
JWT_SECRET=dev_secret_change_in_production
JWT_EXPIRES_IN=8h

# ── Puertos (cada servicio tiene el suyo) ─────────────────────────
AUTH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
CUSTOMER_PROFILE_SERVICE_PORT=3003
PROMOTIONS_SERVICE_PORT=3004
CART_SERVICE_PORT=3005
ORDER_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
INVOICE_SERVICE_PORT=3008
AUDIT_SERVICE_PORT=3009
SAP_INTEGRATION_SERVICE_PORT=3010

FRONTEND_PORT=5173
NGINX_PORT=80

# ── URLs internas entre servicios (nombres de red Docker) ─────────
AUTH_SERVICE_URL=http://auth-service:3001
CATALOG_SERVICE_URL=http://catalog-service:3002
CUSTOMER_PROFILE_SERVICE_URL=http://customer-profile-service:3003
PROMOTIONS_SERVICE_URL=http://promotions-service:3004
CART_SERVICE_URL=http://cart-service:3005
ORDER_SERVICE_URL=http://order-service:3006
NOTIFICATION_SERVICE_URL=http://notification-service:3007
INVOICE_SERVICE_URL=http://invoice-service:3008
AUDIT_SERVICE_URL=http://audit-service:3009
SAP_INTEGRATION_SERVICE_URL=http://sap-integration-service:3010
